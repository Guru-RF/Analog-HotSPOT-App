{
  "name": "hotspot-app",
  "version": "1.0.0",
  "description": "HotSpot — Desktop App for Mac, Windows and Linux (BLE feed viewer)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gururf.hotspot-app",
    "productName": "HotSpot",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/tray-icon.png"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon-512.png",
      "identity": "BVBA WeePee (PTFT4U8MF9)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "PTFT4U8MF9"
      },
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": "HotSpot connects to your hotspot over Bluetooth Low Energy to read the live feed and send DTMF / commands.",
        "NSBluetoothPeripheralUsageDescription": "HotSpot connects to your hotspot over Bluetooth Low Energy to read the live feed and send DTMF / commands."
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon-512.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "Utility",
      "icon": "build/icon-512.png"
    }
  },
  "author": "Guru-RF",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
